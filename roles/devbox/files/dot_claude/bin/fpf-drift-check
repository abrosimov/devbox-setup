#!/usr/bin/env bash
# Check upstream FPF-Spec.md drift; write line count to state file.
# Fast no-op when state file is fresh (<168h old by default).
# Designed to be run in background from prompt/statusline integrations.

set -u

UPSTREAM_URL="https://raw.githubusercontent.com/ailev/FPF/main/FPF-Spec.md"
LOCAL_PATH=""
STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/devbox-setup"
STATE_FILE="${STATE_DIR}/fpf-drift"
TTL_HOURS=168
FORCE=0

usage() {
    cat <<EOF
Usage: fpf-drift-check [--force] [--local PATH]
Writes drifted line count (or "0") to $STATE_FILE.
Skips network call when state file mtime is <${TTL_HOURS}h old, unless --force.
EOF
}

while [ $# -gt 0 ]; do
    case "$1" in
        --force) FORCE=1; shift ;;
        --local) LOCAL_PATH="$2"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) usage >&2; exit 2 ;;
    esac
done

mkdir -p "$STATE_DIR"

# TTL check is cheap — do it first to skip path detection and network call.
if [ "$FORCE" -eq 0 ] && [ -f "$STATE_FILE" ]; then
    if ! find "$STATE_FILE" -mmin "+$((TTL_HOURS * 60))" 2>/dev/null | grep -q .; then
        exit 0
    fi
fi

# Walk up from cwd to find the repo's vendored copy.
if [ -z "$LOCAL_PATH" ]; then
    dir="$(pwd)"
    while [ "$dir" != "/" ]; do
        candidate="$dir/roles/devbox/files/dot_claude/docs/FPF-Spec.md"
        if [ -f "$candidate" ]; then
            LOCAL_PATH="$candidate"
            break
        fi
        dir="$(dirname "$dir")"
    done
fi

if [ -z "$LOCAL_PATH" ] || [ ! -f "$LOCAL_PATH" ]; then
    exit 1
fi

tmp="$(mktemp)" || exit 1
trap 'rm -f "$tmp"' EXIT

if ! curl -sfSL --max-time 10 "$UPSTREAM_URL" -o "$tmp" 2>/dev/null; then
    # Network failed — keep last known state untouched.
    exit 0
fi

drift="$(diff "$tmp" "$LOCAL_PATH" 2>/dev/null | grep -cE '^[<>]' || true)"
echo "${drift:-0}" > "$STATE_FILE"
