{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/pre_bash_toolchain_guard.py"
          },
          {
            "type": "command",
            "command": "~/.claude/bin/pre_tmpdir_guard.py"
          },
          {
            "type": "command",
            "command": "~/.claude/bin/pre_bash_safety_gate.py"
          },
          {
            "type": "command",
            "command": "~/.claude/bin/pre_bash_boundary_wrap.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/pre_tmpdir_guard.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/pre_edit_lint_guard.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/pre_edit_lint_guard.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/pre_write_completion_gate.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/pre_write_existing_guard.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/pre_plan_code_guard.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/pre_plan_code_guard.py"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/pre_plan_code_guard.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/permission_auto_approve.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/suggest_checkpoint.py",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/post_edit_lint.py"
          },
          {
            "type": "command",
            "command": "~/.claude/bin/post_edit_typecheck.py",
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/bin/post_edit_cyrillic_guard.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/post_edit_lint.py"
          },
          {
            "type": "command",
            "command": "~/.claude/bin/post_edit_typecheck.py",
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/bin/post_edit_cyrillic_guard.py"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/post_edit_cyrillic_guard.py"
          }
        ]
      },
      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/post_edit_cyrillic_guard.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/proposal_discipline.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/stop_format.py"
          },
          {
            "type": "command",
            "command": "~/.claude/bin/stop_lint_gate.py"
          },
          {
            "type": "command",
            "command": "~/.claude/bin/proposal_discipline.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/session_save.py"
          },
          {
            "type": "command",
            "command": "~/.claude/bin/pre_compact_mask.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/session_save.py"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/worktree-create",
            "timeout": 30
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/worktree-remove",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
