# Managed by devbox (roles/devbox/files/.config/git/config.j2). This is the XDG
# global config (~/.config/git/config). Git reads it IN ADDITION to ~/.gitconfig,
# and on conflicting keys ~/.gitconfig wins (loaded last).
#
# The `sanitize_gitconfig` task at role start migrates known keys out of
# ~/.gitconfig into this file + identity-{personal,work}.gitconfig, then
# archives ~/.gitconfig to ~/.gitconfig.bak.<timestamp>. So in the steady state
# ~/.gitconfig does not exist and everything lives here or in the identity file.
#
# Behavioral, non-secret settings only — identity (user.name / user.email /
# signingkey / init.defaultBranch / jira.keyPosition) lives per-profile in the
# includeIf targets at the bottom of this file.
#
# OS-specific behavioural keys (e.g. credential.helper = osxkeychain) live in
# ~/.config/git/config-{darwin,linux}, pulled in via [include] at the end.
# When adding/removing keys here, keep `devbox_gitconfig_known_keys` in
# roles/devbox/tasks/sanitize_gitconfig.yml in sync — sanitize aborts on any
# key present in ~/.gitconfig that is not in that allow-list.

# init.defaultBranch is per-profile: master on personal, main on work.
# See identity-{personal,work}.gitconfig, generated by scripts/git-identity-gen.py.

# --- Branchless push/pull -----------------------------------------------------
# `push` / `pull` need no branch argument: current branch, same name on origin.
[push]
	default = simple
	autoSetupRemote = true       # first push auto-creates upstream (git >= 2.37)
	followTags = true            # push annotated tags reachable from pushed commits

[pull]
	ff = only                    # never a surprise merge commit; diverged = stop

[fetch]
	prune = true                 # drop local refs for branches deleted on origin

# --- Merge / rebase quality-of-life -------------------------------------------
# rebase.autoStash and rebase.autosquash deliberately NOT set — silent stashes
# and fixup-collapse have surprised more often than they helped.

[merge]
	conflictStyle = zdiff3       # conflict markers include the common ancestor

[rerere]
	enabled = true               # remember conflict resolutions, replay on redo

[diff]
	algorithm = histogram
	colorMoved = default

# --- Guardrails ---------------------------------------------------------------
[advice]
	detachedHead = true          # warn on detached HEAD (see `sw` abbr / switch)

# --- Core --------------------------------------------------------------------
# Managed core settings. Migrated from ~/.gitconfig on 2026-07-04 (sanitize).
# core.hooksPath enables plain global hooks (prepare-commit-msg Jira key). Repos
# that set their own core.hooksPath (Husky, Lefthook, or an older proj per-repo
# install) win by local-over-global precedence.
[core]
	editor = vim                 # git-native editor stays vim even though EDITOR=nvim
	quotepath = false            # show utf-8 filenames verbatim, no octal escapes
	hooksPath = ~/.config/git/hooks
	autocrlf = input             # normalise incoming CRLF → LF on commit; leave working tree alone

# --- Git LFS filters ---------------------------------------------------------
# Registered here (not by `git lfs install`, which writes into ~/.gitconfig and
# would re-trigger sanitize on next run). git-lfs is a base brew package
# (roles/devbox/defaults/main/packages.yml), so the binary is always present.
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f

# Jira key position for prepare-commit-msg is per-profile (suffix on work,
# no-op on personal — see identity-work.gitconfig).

# --- HTTPS → SSH URL rewrites ------------------------------------------------
# `insteadOf` (not `pushInsteadOf`) — read *and* write go over SSH, keychain
# HTTPS credentials never touched. Applies to fetch, clone, push. A repo cloned
# from https://gitlab.com/foo/bar.git behaves as if cloned from git@gitlab.com:foo/bar.git.
# Works on Linux too provided the SSH key is uploaded to the provider.
[url "git@gitlab.com:"]
	insteadOf = https://gitlab.com/
[url "git@github.com:"]
	insteadOf = https://github.com/

# --- OS-specific overlay -----------------------------------------------------
# Rendered from config-{darwin,linux}.j2 next to this file, deployed only on the
# matching OS by install_configs.yml. Missing include paths are silently ignored
# by git, so a machine that only has one OS's file just no-ops the other line.
[include]
	path = ~/.config/git/config-darwin
[include]
	path = ~/.config/git/config-linux

# --- Per-profile identity -----------------------------------------------------
# Identity is selected by repository location, not by machine profile, so a work
# repo that lands under ~/Projects still gets the right identity. Each file is
# generated by `make git-identity` into the (gitignored) local overlay and
# deployed to ~/.config/git/. A missing include path is silently ignored, so a
# machine that only has one profile's identity file just no-ops the other line.
# Dirs mirror profiles/{personal,work}.yml (devbox_projects_dir).
#
[includeIf "gitdir:~/Projects/"]
	path = ~/.config/git/identity-personal.gitconfig
[includeIf "gitdir:~/Work/"]
	path = ~/.config/git/identity-work.gitconfig
