#!/bin/sh
# post-edit-cyrillic-guard — warns when Cyrillic chars appear in written artifacts.
#
# Project policy: British English in all written artifacts. Conversational responses
# may match the user's language (Russian/English). This hook catches Cyrillic drift
# into files.
#
# Hook: PostToolUse for Edit, Write, MultiEdit, NotebookEdit
# Env:  CC_TOOL_INPUT_FILE_PATH plus tool-specific content fields
#         Edit:         CC_TOOL_INPUT_NEW_STRING
#         Write:        CC_TOOL_INPUT_CONTENT
#         NotebookEdit: CC_TOOL_INPUT_NEW_SOURCE
#         MultiEdit:    falls back to reading file from disk
# Exit: always 0 (non-blocking; the warning is informational).

file_path="${CC_TOOL_INPUT_FILE_PATH:-}"

case "$file_path" in
  */testdata/*|*/fixtures/*|*/__fixtures__/*|*/memory/*) exit 0 ;;
esac

text="${CC_TOOL_INPUT_NEW_STRING:-}${CC_TOOL_INPUT_CONTENT:-}${CC_TOOL_INPUT_NEW_SOURCE:-}"

if [ -z "$text" ] && [ -f "$file_path" ]; then
  text=$(cat "$file_path")
fi

[ -z "$text" ] && exit 0

n=$(printf '%s' "$text" | perl -CSD -ne 'BEGIN{$c=0} $c+=()=/\p{Cyrillic}/g; END{print $c}' 2>/dev/null)

if [ "${n:-0}" -gt 0 ]; then
  echo "WARNING: Cyrillic characters detected ($n) in $file_path. Project policy: written artifacts must be British English. Replace Cyrillic content with British English before committing. See CLAUDE.md > Language Policy." >&2
fi

exit 0
