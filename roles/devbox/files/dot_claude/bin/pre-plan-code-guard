#!/usr/bin/env node

// pre-plan-code-guard — hard guard that keeps source code out of implementation
// plans (plan.md). The implementation planner is a functional analyst: it
// describes WHAT, never HOW. This guard enforces that mechanically.
//
// Two modes:
//   1. Hook mode (default): reads a PreToolUse event from stdin. Intercepts
//      Write/Edit/MultiEdit calls targeting a file named `plan.md`. If the
//      written content contains source code, blocks the write (exit 2).
//   2. CLI mode: `pre-plan-code-guard --file <path>` scans an existing file
//      and exits non-zero if it contains code. Useful for CI / orchestrator
//      validation. `--self-test` runs built-in cases.
//
// Event: PreToolUse (matcher: Write | Edit | MultiEdit)
// Exit 0 = allow / clean, Exit 2 = block / code found, Exit 10 = usage error.
//
// Detection: fenced code blocks tagged with a programming language are always
// rejected; untagged/plain-text fenced blocks are rejected when they contain
// 2+ code signatures. Structured-data blocks (json/yaml/toml/...) and
// diagram/prose blocks (mermaid/markdown/diff) are allowed — the machine
// readable execution DAG belongs in plan_output.json, not plan.md.

const fs = require("fs");
const path = require("path");

// Fenced tags that always mean "this is code".
const CODE_LANGS = new Set([
  "go", "golang",
  "python", "py", "python3",
  "ts", "typescript", "tsx",
  "js", "javascript", "jsx", "mjs", "cjs",
  "java", "kotlin", "kt", "scala", "groovy",
  "rust", "rs",
  "c", "cpp", "c++", "cc", "cxx", "h", "hpp", "hh", "objc",
  "cs", "csharp",
  "ruby", "rb",
  "php",
  "swift",
  "sql", "proto", "protobuf", "graphql", "gql",
]);

// Fenced tags that are explicitly NOT code (structured data, diagrams, prose).
// Bodies of these blocks are not scanned for signatures.
const SAFE_LANGS = new Set([
  "json", "json5", "jsonc",
  "yaml", "yml",
  "toml", "ini", "cfg", "conf", "properties",
  "csv", "tsv",
  "markdown", "md",
  "mermaid",
  "diff", "patch",
  "http",
  "dotenv", "env",
]);

// Untagged/plain blocks are scanned for these strong code signatures.
const CODE_SIGNATURES = [
  /^\s*func\s+[A-Za-z_(]/, // Go function / method
  /^\s*def\s+\w+\s*\(/, // Python def
  /^\s*async\s+def\s+\w+\s*\(/,
  /^\s*class\s+\w+/,
  /^\s*(public|private|protected)\s+(static\s+)?[\w<>\[\]]+\s+\w+/, // Java/C# member
  /^\s*package\s+[\w./]+/,
  /^\s*import\s+[\w.{*]/, // import x / import {x}
  /^\s*from\s+[\w.]+\s+import\s+/,
  /^\s*type\s+\w+\s+(struct|interface)\b/, // Go type decl
  /^\s*(export\s+)?(default\s+)?(function|interface|enum)\s+\w/,
  /^\s*(const|let|var)\s+\w+\s*[:=]/, // JS/TS binding
  /^\s*@[\w.]+(\(|\s*$)/, // decorator / annotation
  /^\s*(if|for|while|switch)\s*\(.*\)\s*\{\s*$/, // C-style control block
  /=>\s*\{?\s*$/, // arrow function
];

const ALWAYS_LANGS = new Set(["bash", "sh", "shell", "zsh", "console"]); // treated as code-ish; scan body
// (bash blocks in a plan usually mean leaked implementation/run steps — scan them)

const FENCE_RE = /(^|\n)[ \t]*(`{3,}|~{3,})[ \t]*([A-Za-z0-9_+#-]*)[ \t]*\n([\s\S]*?)(?:\n[ \t]*\2[ \t]*(?=\n|$))/g;

/**
 * Scan markdown text for leaked code. Returns an array of violation strings
 * (empty if clean).
 */
function findCode(content) {
  const violations = [];
  let m;
  FENCE_RE.lastIndex = 0;
  while ((m = FENCE_RE.exec(content)) !== null) {
    const tag = (m[3] || "").toLowerCase();
    const body = m[4] || "";

    if (CODE_LANGS.has(tag)) {
      violations.push(`fenced \`\`\`${tag} block — source code is not allowed in plan.md`);
      continue;
    }
    if (SAFE_LANGS.has(tag)) {
      continue; // structured data / diagrams / prose — allowed
    }

    // Untagged, plain, or shell block: scan the body for code signatures.
    const lines = body.split("\n");
    let hits = 0;
    for (const line of lines) {
      if (CODE_SIGNATURES.some((re) => re.test(line))) hits += 1;
    }
    const threshold = ALWAYS_LANGS.has(tag) ? 1 : 2;
    if (hits >= threshold) {
      const label = tag ? `\`\`\`${tag}` : "untagged";
      violations.push(`${label} fenced block with ${hits} code signature(s) — describe behaviour instead of code`);
    }
  }
  return violations;
}

const REMEDIATION =
  "\nThe implementation planner describes WHAT, not HOW. Remove the code and\n" +
  "describe the behaviour (inputs, outputs, rules) instead. The machine-readable\n" +
  "execution DAG belongs in plan_output.json, not as a code block in plan.md.\n";

function isPlanFile(filePath) {
  return path.basename(filePath || "") === "plan.md";
}

// --- CLI mode ---

function runCli(argv) {
  if (argv.includes("--self-test")) {
    return selfTest();
  }
  const fileIdx = argv.indexOf("--file");
  if (fileIdx === -1 || !argv[fileIdx + 1]) {
    process.stderr.write("usage: pre-plan-code-guard --file <path> | --self-test\n");
    process.exit(10);
  }
  const filePath = argv[fileIdx + 1];
  let content;
  try {
    content = fs.readFileSync(filePath, "utf-8");
  } catch (e) {
    process.stderr.write(`ERROR: cannot read ${filePath}: ${e.message}\n`);
    process.exit(10);
  }
  const violations = findCode(content);
  if (violations.length > 0) {
    process.stderr.write(`FAIL: ${filePath} contains code:\n  - ${violations.join("\n  - ")}\n${REMEDIATION}`);
    process.exit(2);
  }
  process.stdout.write(`PASS: ${filePath} contains no code blocks\n`);
  process.exit(0);
}

function selfTest() {
  const cases = [
    ["clean prose", "# Plan\n\n| FR | AC |\n|----|----|\n| 1 | x |\n", 0],
    ["go fence", "## X\n\n```go\nfunc Foo() {}\n```\n", 2],
    ["python fence", "```python\ndef foo():\n    pass\n```\n", 2],
    ["json allowed", "```json\n{\"a\": 1}\n```\n", 0],
    ["mermaid allowed", "```mermaid\ngraph TD; A-->B\n```\n", 0],
    ["untagged code", "```\nclass Foo:\n    def bar(self):\n        return 1\n```\n", 2],
    ["untagged prose", "```\nThis is just an example sentence.\nAnother sentence here.\n```\n", 0],
    ["bash leak", "```bash\ngo build ./...\n```\n", 0], // single non-signature line → allowed
    ["bash code leak", "```bash\nfunc main() {}\n```\n", 2],
  ];
  let failed = 0;
  for (const [name, input, want] of cases) {
    const got = findCode(input).length > 0 ? 2 : 0;
    const status = got === want ? "ok  " : "FAIL";
    if (got !== want) failed += 1;
    process.stdout.write(`  [${status}] ${name} (want ${want}, got ${got})\n`);
  }
  process.stdout.write(failed === 0 ? "self-test: PASS\n" : `self-test: ${failed} FAILED\n`);
  process.exit(failed === 0 ? 0 : 1);
}

// --- Hook mode ---

async function runHook() {
  let input = "";
  for await (const chunk of process.stdin) input += chunk;

  let data;
  try {
    data = JSON.parse(input);
  } catch {
    process.exit(0); // not a hook event — do not interfere
  }

  const tool = data.tool_name || "";
  const ti = data.tool_input || {};
  const filePath = ti.file_path || "";

  if (!isPlanFile(filePath)) process.exit(0);

  // Collect the content being written, per tool shape.
  let content = "";
  if (tool === "Write") {
    content = ti.content || "";
  } else if (tool === "Edit") {
    content = ti.new_string || "";
  } else if (tool === "MultiEdit") {
    content = (ti.edits || []).map((e) => e.new_string || "").join("\n");
  } else {
    content = ti.content || ti.new_string || "";
  }

  if (!content) process.exit(0);

  const violations = findCode(content);
  if (violations.length > 0) {
    process.stderr.write(
      `BLOCKED: plan.md may not contain source code.\n  - ${violations.join("\n  - ")}\n${REMEDIATION}`
    );
    process.exit(2);
  }
  process.exit(0);
}

const argv = process.argv.slice(2);
if (argv.includes("--file") || argv.includes("--self-test")) {
  runCli(argv);
} else {
  runHook();
}
